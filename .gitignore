# ==========================================
# Astronomical Data & Databases
# ==========================================
# Ignore the actual downloaded data directory (wherever you sync your SDSS files)
data/
raw_data/
sdss_downloads/

# Ignore SQLite database files generated by your indexer
*.db
*.sqlite
*.sqlite3

# Ignore massive astronomical FITS data files if they happen to wander out of data folders
*.fits
*.fit
*.fts

# ==========================================
# Python Defaults
# ==========================================
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution/packaging
bin/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg

# ==========================================
# Jupyter Notebook Checkpoints
# ==========================================
.ipynb_checkpoints/

# ==========================================
# Virtual Environments
# ==========================================
# If you use a local virtual environment, don't upload thousands of dependency files
venv/
.venv/
env/
.env
ENV/
